# Postgres connection string (use the pooled connection string in production)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Real OpenAI API key for production (chat roleplay + scoring)
OPENAI_API_KEY=sk-...

# Optional: override the default chat model (defaults to gpt-4o-mini)
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional: customer voice playback speed for TTS (0.25–4.0, defaults to 1.12)
OPENAI_TTS_SPEED=1.12

NODE_ENV=production
PORT=5000
