# Postgres connection string (use the pooled connection string in production)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Real OpenAI API key for production (chat roleplay + scoring)
OPENAI_API_KEY=sk-...

# Optional: override the default chat model (defaults to gpt-4o-mini)
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional: customer voice playback speed for TTS (0.25–4.0, defaults to 1.12)
OPENAI_TTS_SPEED=1.12

NODE_ENV=production
PORT=5000

# --- Stripe billing ---
# Secret API key (use a sk_test_... key in test mode). Billing features are disabled
# gracefully if this is unset (demo accounts still work).
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret from `stripe listen` or the Dashboard webhook endpoint.
STRIPE_WEBHOOK_SECRET=whsec_...
# Per-tier Price IDs printed by `npx tsx scripts/stripe-setup.ts` (flat-per-tier v2).
# Consultant seat, one flat monthly rate per plan tier ($49 / $45 / $41).
STRIPE_SEAT_TEAM_PRICE_ID=price_...
STRIPE_SEAT_OFFICE_PRICE_ID=price_...
STRIPE_SEAT_COMPANY_PRICE_ID=price_...
# Optional Manager Dashboard, one flat monthly rate per plan tier ($249 / $389 / $529).
STRIPE_DASHBOARD_TEAM_PRICE_ID=price_...
STRIPE_DASHBOARD_OFFICE_PRICE_ID=price_...
STRIPE_DASHBOARD_COMPANY_PRICE_ID=price_...
# Enterprise (36+) is a custom quote — no self-serve price object.
# Base URL used for Checkout/Portal success & return redirects.
APP_URL=http://localhost:5000

# --- Lead notification emails (Resend) ---
# Required to send an email to hello@solveframework.com when a new lead is
# submitted via POST /api/leads. If unset, lead capture still works — the
# notification is skipped and a warning is logged.
RESEND_API_KEY=re_...
